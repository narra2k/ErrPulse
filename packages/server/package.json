{
  "name": "@errpulse/server",
  "version": "0.1.3",
  "description": "ErrPulse server — Express API + SQLite + WebSocket",
  "license": "MIT",
  "author": "Meghshyam Sonar",
  "homepage": "https://github.com/Meghshyams/ErrPulse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Meghshyams/ErrPulse.git",
    "directory": "packages/server"
  },
  "keywords": [
    "error-monitoring",
    "error-tracking",
    "express",
    "sqlite",
    "websocket",
    "errpulse"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "dashboard/dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@errpulse/core": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
