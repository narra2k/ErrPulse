{
  "name": "@errpulse/node",
  "version": "0.1.4",
  "description": "ErrPulse Node.js backend SDK — catch every backend error automatically",
  "license": "MIT",
  "author": "Meghshyam Sonar",
  "homepage": "https://github.com/Meghshyams/ErrPulse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Meghshyams/ErrPulse.git",
    "directory": "packages/node"
  },
  "keywords": [
    "error-monitoring",
    "error-tracking",
    "nodejs",
    "express",
    "nextjs",
    "backend",
    "errpulse",
    "debugging",
    "error-handler",
    "middleware",
    "uncaught-exception",
    "console-log",
    "devtools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@errpulse/core": "workspace:*",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  }
}
