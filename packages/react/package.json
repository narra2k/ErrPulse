{
  "name": "@errpulse/react",
  "version": "0.1.3",
  "description": "ErrPulse React frontend SDK — catch every frontend error automatically",
  "license": "MIT",
  "author": "Meghshyam Sonar",
  "homepage": "https://github.com/Meghshyams/ErrPulse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Meghshyams/ErrPulse.git",
    "directory": "packages/react"
  },
  "keywords": [
    "error-monitoring",
    "error-tracking",
    "react",
    "error-boundary",
    "frontend",
    "errpulse"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@errpulse/core": "workspace:*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
