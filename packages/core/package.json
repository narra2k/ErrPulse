{
  "name": "@errpulse/core",
  "version": "0.1.4",
  "description": "Shared types, fingerprinting, and error explanations for ErrPulse",
  "license": "MIT",
  "author": "Meghshyam Sonar",
  "homepage": "https://github.com/Meghshyams/ErrPulse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Meghshyams/ErrPulse.git",
    "directory": "packages/core"
  },
  "keywords": [
    "error-monitoring",
    "error-tracking",
    "fingerprinting",
    "errpulse"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
